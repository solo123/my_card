# Copy to .env and adjust. Loaded automatically from apps/backend/.env on startup.

DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/my_card

# Required in production — use a long random string
JWT_SECRET=dev-secret-change-in-production

# Optional (seconds)
# JWT_ACCESS_EXPIRE_SECONDS=7200
# JWT_REFRESH_EXPIRE_SECONDS=604800
